<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 64 }}">
    {%- endif -%}
    <title>{{ shop.name }}</title>
    {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
    {{ content_for_header }}

    {%- liquid
      assign body_font = settings.font_body
      assign heading_font = settings.font_heading
    -%}
    <style>
      {{ body_font | font_face: font_display: 'swap' }}
      {{ heading_font | font_face: font_display: 'swap' }}

      :root {
        --color-ink: {{ settings.color_ink }};
        --color-bg: {{ settings.color_bg }};
        --color-surface: {{ settings.color_surface }};
        --color-accent: {{ settings.color_accent }};
        --color-accent-contrast: {{ settings.color_accent_contrast }};
        --color-muted: {{ settings.color_muted }};
        --page-width: {{ settings.page_width }}px;
        --radius: {{ settings.corner_radius }}px;
        --heading-scale: {{ settings.heading_scale | divided_by: 100.0 }};
        --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
        --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
      }
    </style>
    {{ 'base.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-password">
    <main class="password-page">
      <div class="password-card">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 360 }}" alt="{{ shop.name }}" width="{{ settings.logo_width }}">
        {%- else -%}
          <h1 class="password-logo">{{ settings.brand_name | default: shop.name }}</h1>
        {%- endif -%}
        <p class="password-tag">Something sleek is coming.</p>

        {% form 'storefront_password' %}
          {% if form.errors %}
            <p class="form-error">{{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}</p>
          {% endif %}
          <div class="password-field">
            <input type="password" name="password" id="password" placeholder="Enter store password" required>
            <button type="submit" class="btn btn--accent">Enter</button>
          </div>
        {% endform %}
      </div>
    </main>
  </body>
</html>
