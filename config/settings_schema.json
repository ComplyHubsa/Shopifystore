[
  {
    "name": "theme_info",
    "theme_name": "Lúma",
    "theme_version": "1.0.0",
    "theme_author": "WebFlow Studio",
    "theme_documentation_url": "https://shopify.dev/themes",
    "theme_support_url": "https://shopify.dev/themes"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "text",
        "id": "brand_name",
        "label": "Brand name",
        "default": "Lúma",
        "info": "Used in the header when no logo is set."
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 60,
        "max": 240,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 120
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_ink",
        "label": "Ink / text",
        "default": "#211B20"
      },
      {
        "type": "color",
        "id": "color_bg",
        "label": "Page background",
        "default": "#F8F2F1"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Card / surface",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#BC8A86"
      },
      {
        "type": "color",
        "id": "color_accent_contrast",
        "label": "Accent text",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text",
        "default": "#80747A"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 90,
        "max": 140,
        "step": 5,
        "unit": "%",
        "label": "Heading size",
        "default": 110
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1100,
        "max": 1500,
        "step": 20,
        "unit": "px",
        "label": "Max page width",
        "default": 1280
      },
      {
        "type": "range",
        "id": "corner_radius",
        "min": 0,
        "max": 28,
        "step": 2,
        "unit": "px",
        "label": "Corner radius",
        "default": 14
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "text", "id": "social_tiktok", "label": "TikTok URL" },
      { "type": "text", "id": "social_facebook", "label": "Facebook URL" }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_free_ship_bar",
        "label": "Show free-shipping progress bar",
        "default": true
      },
      {
        "type": "number",
        "id": "free_ship_threshold",
        "label": "Free shipping threshold (in ZAR)",
        "default": 500,
        "info": "Order total at which shipping becomes free."
      }
    ]
  }
]
