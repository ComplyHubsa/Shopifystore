{%- comment -%} Footer social links pulled from theme settings {%- endcomment -%}
<div class="footer__social">
  {%- if settings.social_instagram != blank -%}
    <a href="{{ settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">IG</a>
  {%- endif -%}
  {%- if settings.social_tiktok != blank -%}
    <a href="{{ settings.social_tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">TT</a>
  {%- endif -%}
  {%- if settings.social_facebook != blank -%}
    <a href="{{ settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">FB</a>
  {%- endif -%}
</div>
