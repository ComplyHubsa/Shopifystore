<section class="hero">
  <div class="page-width hero__grid">
    <div class="hero__content">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h1 class="hero__title">{{ section.settings.heading }}</h1>
      <p class="lede">{{ section.settings.subheading }}</p>

      <div class="hero__cta">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn btn--accent btn--lg">{{ section.settings.button_label }}</a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="btn btn--lg">{{ section.settings.button_label_2 }}</a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_rating -%}
        <div class="hero__rating">
          <span class="stars">★★★★★</span>
          <span>{{ section.settings.rating_text }}</span>
        </div>
      {%- endif -%}
    </div>

    <div class="hero__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 900 | image_tag: widths: '450, 700, 900', sizes: '(max-width: 749px) 100vw, 45vw', alt: section.settings.heading | escape }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' }}
      {%- endif -%}
      {%- if section.settings.badge != blank -%}<span class="hero__badge">{{ section.settings.badge }}</span>{%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Slick-back · Flyaways · Edges" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Not a hair out of place." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Sleeq Slick Stick tames flyaways, baby hairs and edges in one swipe — strong all-day hold, zero flakes, zero grease. Your slick bun's new best friend." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the Slick Stick" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "button_label_2", "label": "Secondary button label", "default": "How it works" },
    { "type": "url", "id": "button_link_2", "label": "Secondary button link", "default": "#how-to" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "badge", "label": "Image badge", "default": "Beeswax + Castor Oil" },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating", "default": true },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "Loved by 4,000+ sleek-hair fans" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
