<section class="section" style="background:{{ section.settings.bg }}">
  <div class="page-width">
    <div class="section-heading text-center">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="reviews">
      {%- for block in section.blocks -%}
        <figure class="review" {{ block.shopify_attributes }}>
          <div class="review__stars">★★★★★</div>
          <blockquote style="margin:0">{{ block.settings.quote }}</blockquote>
          <figcaption class="review__name">{{ block.settings.name }} <span>· {{ block.settings.location }}</span></figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "★★★★★ 4.9 average" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What the slick-hair crowd says" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#EFE7DA" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Obsessed. My slick bun finally stays put through a full workday." },
        { "type": "text", "id": "name", "label": "Name", "default": "Thandi M." },
        { "type": "text", "id": "location", "label": "Location", "default": "Johannesburg" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review", "settings": { "quote": "Obsessed. My slick bun finally stays put through a full Joburg workday — no flyaways by 5pm.", "name": "Thandi M.", "location": "Johannesburg" } },
        { "type": "review", "settings": { "quote": "Way better than gel. No crunch, no white flakes, and it actually smells nice. Lasts me ages too.", "name": "Aisha P.", "location": "Cape Town" } },
        { "type": "review", "settings": { "quote": "Got it for my edges and ended up using it on my brows and my partner's slick-back. One stick, whole house.", "name": "Lerato K.", "location": "Durban" } }
      ]
    }
  ]
}
{% endschema %}
