<section class="section">
  <div class="page-width">
    <div class="newsletter">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      <p style="color:rgba(255,255,255,.8); max-width:48ch; margin-inline:auto">{{ section.settings.text }}</p>
      {% form 'customer', class: 'newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p style="color:var(--color-accent); margin-top:18px">{{ 'general.newsletter.success' | t }}</p>
        {%- else -%}
          <div class="field-row">
            <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.placeholder' | t }}" required aria-label="Email">
            <button type="submit" class="btn btn--accent">{{ 'general.newsletter.button' | t }}</button>
          </div>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the list" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 10% off your first slick" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Sign up for a welcome discount, restock alerts and slick-hair tips. No spam, ever." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
