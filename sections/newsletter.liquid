<section class="section">
  <div class="page-width">
    <div class="newsletter newsflip" data-newsflip>
      <div class="newsflip__inner">
        <div class="newsflip__face newsflip__front">
          {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
          <h2>{{ section.settings.heading }}</h2>
          <p style="color:rgba(255,255,255,.8); max-width:48ch; margin-inline:auto">{{ section.settings.text }}</p>
          {% form 'customer', id: 'luma-news' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            {%- if form.posted_successfully? -%}
              <p style="color:var(--color-accent); margin-top:18px; font-weight:700">You're in! Use code <strong>{{ section.settings.code }}</strong> for 10% off.</p>
            {%- else -%}
              <div class="field-row">
                <input type="email" name="contact[email]" placeholder="Your email address" required aria-label="Email">
                <button type="submit" class="btn btn--accent">{{ section.settings.button_label }}</button>
              </div>
            {%- endif -%}
          {% endform %}
        </div>
        <div class="newsflip__face newsflip__back">
          <p class="eyebrow">Here's your code</p>
          <div class="newsflip__code">{{ section.settings.code }}</div>
          <p style="color:rgba(255,255,255,.8); margin:0">10% off your first order — enter it at checkout.</p>
          <div class="newsflip__actions">
            <button type="button" class="btn btn--accent" data-copy="{{ section.settings.code }}">Copy code</button>
            <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn newsflip__shop">Shop now</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var wrap = document.currentScript.previousElementSibling.querySelector('[data-newsflip]') || document.querySelector('[data-newsflip]');
    if (!wrap) return;
    var form = wrap.querySelector('form');
    if (form) {
      form.addEventListener('submit', function (e) {
        var email = form.querySelector('[name="contact[email]"]');
        if (!email || !email.value) return;
        e.preventDefault();
        try { fetch(form.action, { method: 'POST', body: new FormData(form) }); } catch (err) {}
        wrap.classList.add('is-flipped');
      });
    }
    wrap.addEventListener('click', function (e) {
      var b = e.target.closest('[data-copy]');
      if (!b) return;
      try { navigator.clipboard.writeText(b.getAttribute('data-copy')); b.textContent = 'Copied!'; } catch (err) {}
    });
  })();
</script>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the list" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 10% off your first Auvé" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Drop your email for an instant 10% code, plus restock alerts and skin-tech tips. No spam, ever." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Get my code" },
    { "type": "text", "id": "code", "label": "Discount code", "default": "WELCOME10" },
    { "type": "url", "id": "button_link", "label": "Shop button link" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
