<section class="section">
  <div class="page-width">
    <div class="guarantee">
      {% render 'icon', name: section.settings.icon, size: 42 %}
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn btn--accent btn--lg">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantee",
  "settings": [
    {
      "type": "select", "id": "icon", "label": "Icon", "default": "secure",
      "options": [
        { "value": "secure", "label": "Shield" },
        { "value": "returns", "label": "Returns" },
        { "value": "star", "label": "Star" },
        { "value": "check", "label": "Check" }
      ]
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Lift it, or your money back." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Try Lúma for 30 days. If you're not seeing the lift, we'll refund you in full — even if you've used it." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the Sculptor" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Guarantee" }]
}
{% endschema %}
