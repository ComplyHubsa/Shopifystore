<section class="section section--tight">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading text-center">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    <div class="benefits">
      {%- for block in section.blocks -%}
        <div class="benefit" {{ block.shopify_attributes }}>
          <div class="benefit__icon">{{ block.settings.icon }}</div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why it works" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "✦" },
        { "type": "text", "id": "title", "label": "Title", "default": "All-day hold" },
        { "type": "text", "id": "text", "label": "Text", "default": "Locks flyaways down from morning to night." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "💪", "title": "Strong hold", "text": "Salon-grade grip that lasts all day, even in humidity." } },
        { "type": "benefit", "settings": { "icon": "🪶", "title": "No flakes", "text": "Smooth wax glide — never crunchy, white or stiff." } },
        { "type": "benefit", "settings": { "icon": "🌿", "title": "Nourishing", "text": "Beeswax + castor oil condition while they hold." } },
        { "type": "benefit", "settings": { "icon": "⚡", "title": "One swipe", "text": "Mess-free stick — touch up anywhere in seconds." } }
      ]
    }
  ]
}
{% endschema %}
