<section class="section section--tight">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading text-center">
        {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    <div class="benefits">
      {%- for block in section.blocks -%}
        <div class="benefit" {{ block.shopify_attributes }}>
          <div class="benefit__ico">{% render 'icon', name: block.settings.icon, size: 26 %}</div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three salon technologies, one device" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "lift",
          "options": [
            { "value": "lift", "label": "Lift" },
            { "value": "sculpt", "label": "Sculpt / EMS" },
            { "value": "led", "label": "LED" },
            { "value": "depuff", "label": "De-puff" },
            { "value": "shipping", "label": "Shipping" },
            { "value": "returns", "label": "Returns" },
            { "value": "secure", "label": "Secure" },
            { "value": "star", "label": "Star" },
            { "value": "leaf", "label": "Natural" },
            { "value": "clock", "label": "Time" },
            { "value": "spark", "label": "Spark" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Microcurrent lift" },
        { "type": "text", "id": "text", "label": "Text", "default": "Works the facial muscles for a visibly lifted look." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "lift", "title": "Microcurrent lift", "text": "Works the facial muscles for a visibly lifted look." } },
        { "type": "benefit", "settings": { "icon": "sculpt", "title": "EMS sculpting", "text": "Targets the jaw, neck and double chin for a defined V-shape." } },
        { "type": "benefit", "settings": { "icon": "led", "title": "7-colour LED", "text": "Red light to support firmer, glowier-looking skin." } },
        { "type": "benefit", "settings": { "icon": "depuff", "title": "De-puff & glow", "text": "Boost circulation and drain puffiness in just 5 minutes." } }
      ]
    }
  ]
}
{% endschema %}
