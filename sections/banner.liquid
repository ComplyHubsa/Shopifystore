<section class="banner">
  <div class="banner__media" style="background-image: url('{{ section.settings.image_url }}');"></div>
  <div class="banner__scrim"></div>
  <div class="page-width banner__inner">
    <div class="banner__content">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h1 class="banner__title">{{ section.settings.heading }}</h1>

      {%- if section.settings.show_rating -%}
        <p class="banner__rating">
          {% render 'icon', name: 'star', size: 15 %}{% render 'icon', name: 'star', size: 15 %}{% render 'icon', name: 'star', size: 15 %}{% render 'icon', name: 'star', size: 15 %}{% render 'icon', name: 'star', size: 15 %}
          <span>{{ section.settings.rating_text }}</span>
        </p>
      {%- endif -%}

      <p class="banner__sub">{{ section.settings.subheading }}</p>

      <div class="banner__cta">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn btn--accent btn--lg">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>

      <ul class="banner__perks">
        <li>{% render 'icon', name: 'check', size: 15 %} Free SA shipping</li>
        <li>{% render 'icon', name: 'check', size: 15 %} 30-day money-back</li>
        <li>{% render 'icon', name: 'check', size: 15 %} Tracked delivery</li>
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Banner hero",
  "settings": [
    { "type": "text", "id": "image_url", "label": "Image URL", "default": "https://i.postimg.cc/bNn8bPmh/Screenshot-2026-06-17-at-16-19-54.png", "info": "Direct image link, or upload to Content > Files and paste the link." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Microcurrent · EMS · 7-colour LED" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your 5-minute facelift." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Lift, sculpt and firm — a snatched jawline, a defined neck and brighter skin. Salon tech, on your bathroom counter." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the Sculptor" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating", "default": true },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "Loved by 8,000+" }
  ],
  "presets": [{ "name": "Banner hero" }]
}
{% endschema %}
