<section class="section">
  <div class="page-width">
    <div class="section-heading text-center">
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="lede rte" style="margin-inline:auto">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    {%- if collection.products.size > 0 -%}
      {%- paginate collection.products by section.settings.per_page -%}
        <div class="card-grid">
          {%- for product in collection.products -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" style="display:flex; gap:14px; justify-content:center; margin-top:36px; font-weight:600">
            {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">← {{ 'general.pagination.previous' | t }}</a>{%- endif -%}
            {%- if paginate.next -%}<a href="{{ paginate.next.url }}">{{ 'general.pagination.next' | t }} →</a>{%- endif -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <p class="text-center muted">No products in this collection yet.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [
    { "type": "range", "id": "per_page", "min": 6, "max": 24, "step": 3, "label": "Products per page", "default": 12 }
  ]
}
{% endschema %}
