<section class="section">
  <div class="page-width">
    <div class="section-heading text-center"><h1>{{ blog.title }}</h1></div>
    <div class="card-grid">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="card">
          <div class="card__media">
            {%- if article.image -%}
              {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder' }}
            {%- endif -%}
          </div>
          <div class="card__body">
            <div class="card__title">{{ article.title }}</div>
            <p class="muted" style="margin:0">{{ article.excerpt_or_content | strip_html | truncatewords: 18 }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Blog posts", "settings": [] }
{% endschema %}
