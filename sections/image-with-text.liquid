<section class="section">
  <div class="page-width">
    <div class="iwt {% if section.settings.layout == 'reverse' %}iwt--reverse{% endif %}">
      <div class="iwt__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 800 | image_tag: widths: '400, 600, 800', sizes: '(max-width: 749px) 100vw, 50vw', alt: section.settings.heading | escape }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>
      <div class="iwt__content">
        {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <div class="rte">{{ section.settings.text }}</div>
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn btn--ink" style="margin-top:14px">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select", "id": "layout", "label": "Image side", "default": "normal",
      "options": [ { "value": "normal", "label": "Left" }, { "value": "reverse", "label": "Right" } ]
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The formula" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hold that loves your hair back" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>We skipped the cheap stiffening agents. Sleeq is built on a <strong>beeswax base infused with castor oil and vitamin E</strong> — so while it grips every flyaway, it's conditioning your strands and edges, not drying them out. Non-greasy, no white cast, no crunch.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Get yours" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}
