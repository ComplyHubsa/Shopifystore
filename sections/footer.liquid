<footer class="site-footer">
  <div class="page-width">
    <div class="footer__grid">
      <div>
        <div class="footer__brand">{{ settings.brand_name | default: shop.name }}</div>
        <p style="color:rgba(255,255,255,.7); max-width:36ch; margin-top:10px">{{ section.settings.blurb }}</p>
        {% render 'social-icons' %}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            {%- for link in block.settings.menu.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ settings.brand_name | default: shop.name }}. All rights reserved.</span>
      <span>{{ shop.address.country | default: 'South Africa' }} · Prices in {{ shop.currency }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "blurb",
      "label": "Brand blurb",
      "default": "Salon-grade microcurrent, in 5 minutes a day. Lift, sculpt and glow — at a fraction of the price."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu" },
        { "type": "menu" }
      ]
    }
  ]
}
{% endschema %}
