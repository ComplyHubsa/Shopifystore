<section class="section">
  <div class="page-width">
    <h1>{{ 'general.search.search' | t }}</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" class="field-row" style="margin:0 0 30px; max-width:560px">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" aria-label="Search">
      <button type="submit" class="btn btn--accent">{{ 'general.search.search' | t }}</button>
    </form>

    {%- if search.performed -%}
      {%- if search.results.size > 0 -%}
        <p class="muted">{{ 'general.search.results_count' | t: count: search.results_count }}</p>
        <div class="card-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="lede">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
